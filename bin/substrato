#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
root_dir=$(CDPATH= cd -- "$script_dir/.." && pwd)

command=${1:-help}
if [ "$#" -gt 0 ]; then
  shift
fi

case "$command" in
  install)
    "$root_dir/installers/install.sh" "$@"
    ;;
  uninstall)
    "$root_dir/installers/install.sh" --action uninstall "$@"
    ;;
  update)
    git -C "$root_dir" pull --ff-only
    ;;
  help|-h|--help)
    cat <<'EOF'
Usage:
  substrato install [--target auto|agents|codex|gemini|opencode|antigravity|claude|workspace] [--project PATH] [--mode copy|link]
  substrato uninstall [--target auto|agents|codex|gemini|opencode|antigravity|claude|workspace] [--project PATH]
  substrato update
EOF
    ;;
  *)
    printf 'Unknown command: %s\n' "$command" >&2
    exit 1
    ;;
esac
